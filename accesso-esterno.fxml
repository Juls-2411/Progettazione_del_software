<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.org/javafx"
           xmlns:fx="http://javafx.org/fxml"
           fx:controller="com.example.gestioneafam.boundary.AccessoEsternoBoundary"
           prefWidth="520" prefHeight="560">

    <VBox styleClass="card" alignment="CENTER" spacing="10" maxWidth="440">
        <padding><Insets top="10" bottom="10" left="10" right="10"/></padding>

        <ImageView fitWidth="120" preserveRatio="true">
            <Image url="@../../../../images/logo.png"/>
        </ImageView>

        <Label text="Accesso a Contenuti Condivisi" styleClass="title-label"/>
        <Label fx:id="lblErrore" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

        <!-- STEP 1: incolla il link ricevuto -->
        <VBox fx:id="stepUrl" alignment="CENTER" spacing="8">
            <Label text="Incolla qui il link di condivisione ricevuto." styleClass="subtitle-label" wrapText="true"/>
            <TextField fx:id="txtUrl" promptText="https://afam.local/condivisi/..." styleClass="text-field"/>
            <Button text="Apri Link" styleClass="btn-primary" maxWidth="Infinity" onAction="#onApriLink"/>
        </VBox>

        <!-- STEP 2: password (solo se richiesta) -->
        <VBox fx:id="stepPassword" alignment="CENTER" spacing="8" visible="false" managed="false">
            <Label text="Questo contenuto e' protetto da password." styleClass="subtitle-label"/>
            <PasswordField fx:id="txtPassword" promptText="Password" styleClass="password-field"/>
            <Button text="Sblocca Contenuto" styleClass="btn-primary" maxWidth="Infinity" onAction="#onSbloccaConPassword"/>
        </VBox>

        <!-- STEP 3: disclaimer sul diritto d'autore -->
        <VBox fx:id="stepDisclaimer" alignment="CENTER" spacing="8" visible="false" managed="false">
            <Label text="Dichiarazione sul Diritto d'Autore" styleClass="subtitle-label"/>
            <Label text="Tutto il materiale disponibile, inclusi documenti, audio e video, e' protetto da copyright. La visualizzazione e' autorizzata esclusivamente per le finalita' per cui il link e' stato condiviso. E' vietata la copia, la distribuzione o la modifica dei contenuti senza autorizzazione espressa dell'autore."
                   wrapText="true" textAlignment="CENTER"/>
            <CheckBox fx:id="chkAccettaDisclaimer" text="Ho letto e accetto"/>
            <Button fx:id="btnVisualizzaContenuti" text="Visualizza Contenuti" styleClass="btn-primary"
                    maxWidth="Infinity" disable="true" onAction="#onVisualizzaContenuti"/>
        </VBox>

        <Button text="Torna al Login" styleClass="btn-secondary" onAction="#onTornaAlLogin"/>
    </VBox>

    <!-- STEP 4: contenuti condivisi (a schermo intero) -->
    <ScrollPane fx:id="stepContenutiScroll" fitToWidth="true" visible="false" managed="false">
        <VBox fx:id="stepContenuti" spacing="12" visible="false" managed="false">
            <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>
            <Label text="Contenuti Condivisi" styleClass="title-label"/>
            <VBox fx:id="listaContenuti" spacing="10"/>
            <Button text="Torna al Login" styleClass="btn-secondary" onAction="#onTornaAlLogin"/>
        </VBox>
    </ScrollPane>
</StackPane>
