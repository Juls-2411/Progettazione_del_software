<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.org/javafx"
            xmlns:fx="http://javafx.org/fxml"
            fx:controller="com.example.gestioneafam.boundary.ContenutiBoundary"
            prefWidth="1000" prefHeight="640">

    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="220">
            <Button text="📄 Contenuti" styleClass="sidebar-link-active" onAction="#onTornaAllaDashboard"/>
            <Button text="⬅ Torna alla Home" styleClass="sidebar-link" onAction="#onTornaAllaDashboard"/>
            <VBox VBox.vgrow="ALWAYS"/>
            <Button text="➜ LOGOUT" styleClass="logout-btn" maxWidth="Infinity" onAction="#onLogout"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content" spacing="14">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <Label text="Area Contenuti" styleClass="title-label"/>

            <!-- Cartelle -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Cartella:" styleClass="subtitle-label"/>
                <ComboBox fx:id="cmbFiltroCartella" prefWidth="200"/>
                <TextField fx:id="txtNuovaCartella" promptText="Nuova cartella" prefWidth="160"/>
                <Button text="＋ Crea Cartella" styleClass="btn-secondary" onAction="#onCreaCartella"/>
                <Button text="✎ Rinomina Cartella" styleClass="btn-secondary" onAction="#onRinominaCartella"/>
                <Button text="🗑 Elimina Cartella" styleClass="btn-secondary" onAction="#onEliminaCartella"/>
            </HBox>

            <!-- Toolbar aggiunta contenuto -->
            <HBox spacing="10">
                <Button text="⬆ Carica File" styleClass="btn-primary" onAction="#onMostraFormFile"
                        prefWidth="130"
                        prefHeight="40"
                        style="-fx-padding: 8 15; -fx-font-size: 14px;"/>
                <Button text="🔗 Aggiungi Link" styleClass="btn-secondary" onAction="#onMostraFormLink" prefWidth="130"
                        prefHeight="40"
                        style="-fx-padding: 8 15; -fx-font-size: 14px;"/>
            </HBox>

            <!-- Form: nuovo contenuto file -->
            <VBox fx:id="formFile" styleClass="card" spacing="8" visible="false" managed="false">
                <Label text="1. Seleziona i Contenuti da Caricare" styleClass="subtitle-label"/>
                <HBox spacing="10">
                    <RadioButton fx:id="rbAudio" text="Audio (mp3/wav)" selected="true">
                        <toggleGroup><ToggleGroup fx:id="tipoFileGroup"/></toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="rbVideo" text="Video (mp4/mov)" toggleGroup="$tipoFileGroup"/>
                    <RadioButton fx:id="rbSpartito" text="Spartito (pdf)" toggleGroup="$tipoFileGroup"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="lblFileSelezionato" text="Nessun file selezionato" styleClass="subtitle-label" wrapText="true"/>
                    <Button text="Scegli File..." styleClass="btn-secondary" onAction="#onScegliFile"/>
                </HBox>
                <TextField fx:id="txtTitoloFile" promptText="Titolo"/>
                <TextField fx:id="txtDidascaliaFile" promptText="Didascalia"/>
                <TextField fx:id="txtAltFile" promptText="Testo alternativo (accessibilita')"/>
                <Label text="Dichiaro, sotto la mia responsabilita', di essere l'autore del contenuto che sto caricando o di detenerne i diritti di utilizzo, sollevando l'istituzione AFAM da ogni responsabilita' in merito alla sua originalita' e pubblicazione."
                       styleClass="subtitle-label" wrapText="true"/>
                <Label fx:id="lblEsitoFile" wrapText="true" managed="false" visible="false"/>
                <HBox spacing="10">
                    <Button text="Conferma e Carica" styleClass="btn-primary" onAction="#onConfermaFile"/>
                    <Button text="Annulla" styleClass="btn-secondary" onAction="#onAnnullaForm"/>
                </HBox>
            </VBox>

            <!-- Form: nuovo contenuto link -->
            <VBox fx:id="formLink" styleClass="card" spacing="8" visible="false" managed="false">
                <Label text="Aggiungi Collegamento a Piattaforma Esterna" styleClass="subtitle-label"/>
                <TextField fx:id="txtUrlLink" promptText="https://..."/>
                <TextField fx:id="txtTitoloLink" promptText="Titolo"/>
                <TextField fx:id="txtDidascaliaLink" promptText="Didascalia"/>
                <TextField fx:id="txtAltLink" promptText="Testo alternativo (accessibilita')"/>
                <Label fx:id="lblEsitoLink" wrapText="true" managed="false" visible="false"/>
                <HBox spacing="10">
                    <Button text="Conferma" styleClass="btn-primary" onAction="#onConfermaLink"/>
                    <Button text="Annulla" styleClass="btn-secondary" onAction="#onAnnullaForm"/>
                </HBox>
            </VBox>

            <TableView fx:id="tabellaContenuti" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
