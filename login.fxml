<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.org/javafx"
           xmlns:fx="http://javafx.org/fxml"
           fx:controller="com.example.gestioneafam.boundary.LoginBoundary"
           prefWidth="420" prefHeight="480">

    <VBox styleClass="card" alignment="CENTER" spacing="8" maxWidth="340">
        <padding><Insets top="10" bottom="10" left="10" right="10"/></padding>

        <ImageView fitWidth="150" preserveRatio="true">
            <Image url="@../../../../images/logo.png"/>
        </ImageView>

        <Label text="Accesso al Portale" styleClass="title-label"/>

        <Label fx:id="lblErrore" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

        <TextField fx:id="txtUsername" promptText="Email istituzionale" styleClass="text-field"/>
        <PasswordField fx:id="txtPassword" promptText="Password" styleClass="password-field"/>

        <Button text="ACCEDI CON CREDENZIALI AFAM" styleClass="btn-primary" maxWidth="Infinity"
                onAction="#onAccedi" defaultButton="true"/>

        <Button text="ACCEDI CON SPID / eIDAS" styleClass="btn-secondary" maxWidth="Infinity"
                onAction="#onAccediSpid"/>

        <VBox alignment="CENTER" spacing="2">
            <Button text="Hai dimenticato la password? Recupero password" styleClass="btn-secondary"
                    onAction="#onRecuperoPassword"/>
            <Button text="Non sei registrato? Registrati" styleClass="btn-secondary"
                    onAction="#onRegistrazione"/>
            <Button text="Hai ricevuto un link di condivisione? Aprilo qui" styleClass="btn-secondary"
                    onAction="#onAccessoEsterno"/>
        </VBox>
    </VBox>
</StackPane>
