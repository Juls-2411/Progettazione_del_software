<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.org/javafx"
            xmlns:fx="http://javafx.org/fxml"
            fx:controller="com.example.gestioneafam.boundary.RiscontriBoundary"
            prefWidth="760" prefHeight="520">

    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="220">
            <Button text="📈 Riscontri" styleClass="sidebar-link-active" onAction="#onTornaAllaDashboard"/>
            <Button text="⬅ Torna alla Home" styleClass="sidebar-link" onAction="#onTornaAllaDashboard"/>
            <VBox VBox.vgrow="ALWAYS"/>
            <Button text="➜ LOGOUT" styleClass="logout-btn" maxWidth="Infinity" onAction="#onLogout"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content" spacing="14">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
            <Label text="Riscontri di Visualizzazione" styleClass="title-label"/>
            <Label text="Per ciascun link condiviso, numero di aperture e data dell'ultimo accesso. Nessun dato tecnico sul visitatore viene registrato."
                   styleClass="subtitle-label" wrapText="true"/>
            <Label fx:id="lblNessunRiscontro" styleClass="subtitle-label" managed="false" visible="false"/>
            <TableView fx:id="tabellaRiscontri" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
