<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.org/javafx"
           xmlns:fx="http://javafx.org/fxml"
           fx:controller="com.example.gestioneafam.boundary.SpidEidasBoundary"
           prefWidth="440" prefHeight="560">

    <VBox styleClass="card" alignment="CENTER" spacing="10" maxWidth="380">
        <padding><Insets top="10" bottom="10" left="10" right="10"/></padding>

        <ImageView fitWidth="120" preserveRatio="true">
            <Image url="@../../../../images/logo.png"/>
        </ImageView>

        <Label text="Accesso con Identita' Digitale" styleClass="title-label"/>
        <Label fx:id="lblErrore" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

        <!-- STEP 1: scelta SPID oppure eIDAS -->
        <VBox fx:id="stepScelta" alignment="CENTER" spacing="10">
            <Label text="Con quale identita' digitale vuoi accedere?" styleClass="subtitle-label" wrapText="true"/>
            <Button text="Accedi con SPID" styleClass="btn-primary" maxWidth="Infinity" onAction="#onSceltaSpid"/>
            <Button text="Accedi con eIDAS (identita' europea)" styleClass="btn-secondary" maxWidth="Infinity"
                    onAction="#onSceltaEidas"/>
        </VBox>

        <!-- STEP 2: selezione Identity Provider (SPID) o Paese (eIDAS) -->
        <VBox fx:id="stepProvider" alignment="CENTER" spacing="8" visible="false" managed="false">
            <Label fx:id="lblTitoloProvider" text="Seleziona il tuo Identity Provider" styleClass="subtitle-label" wrapText="true"/>
            <ListView fx:id="listaProvider" prefHeight="160"/>
            <Button text="Continua" styleClass="btn-primary" maxWidth="Infinity" onAction="#onContinuaProvider"/>
            <Button text="Indietro" styleClass="btn-secondary" onAction="#onIndietroDaProvider"/>
        </VBox>

        <!-- STEP 3: "login" simulato presso il provider -->
        <VBox fx:id="stepLogin" alignment="CENTER" spacing="8" visible="false" managed="false">
            <Label text="Stai per essere reindirizzato al portale del tuo Identity Provider (simulato)."
                   styleClass="subtitle-label" wrapText="true" textAlignment="CENTER"/>
            <Label text="Seleziona un'identita' di test per simulare l'autenticazione:" styleClass="subtitle-label" wrapText="true"/>
            <ListView fx:id="listaIdentita" prefHeight="140"/>
            <CheckBox fx:id="chkSimulaFallimento" text="Simula autenticazione fallita/annullata sul provider"/>
            <CheckBox fx:id="chkSimulaTimeout" text="Simula timeout di connessione con il provider"/>
            <Button text="Accedi" styleClass="btn-primary" maxWidth="Infinity" onAction="#onAccedi"/>
            <Button text="Indietro" styleClass="btn-secondary" onAction="#onIndietroDaLogin"/>
        </VBox>

        <Button text="Torna al Login" styleClass="btn-secondary" onAction="#onTornaAlLogin"/>
    </VBox>
</StackPane>
